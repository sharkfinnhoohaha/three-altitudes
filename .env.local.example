# Sanity CMS
# Create a project at https://sanity.io/manage then fill these in
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API tokens — create at sanity.io/manage → project → API → Tokens
SANITY_API_READ_TOKEN=your-read-token
# Same value as SANITY_API_READ_TOKEN — needs NEXT_PUBLIC_ prefix for browser live updates
NEXT_PUBLIC_SANITY_API_READ_TOKEN=your-read-token

# Draft mode secret — any random string, must match Sanity Presentation tool config
SANITY_PREVIEW_SECRET=your-preview-secret
